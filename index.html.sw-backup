<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Wardrobe — Complete</title>
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#111827">
  <style>
    :root{--bg:#ffffff;--muted:#6b7280;--accent:#111827;--card:#ffffff;--border:#e6e6e6;--primary:#111827;--soft:#f7f7f7}
    *{box-sizing:border-box}body{margin:0;font-family:Inter,system-ui,-apple-system,'Segoe UI',Roboto,Arial;color:var(--accent);background:var(--bg);-webkit-font-smoothing:antialiased}
    header{display:flex;justify-content:space-between;align-items:center;padding:18px 20px;border-bottom:1px solid var(--border);max-width:1100px;margin:0 auto}
    .brand{font-family:Georgia,serif;font-weight:700;letter-spacing:1px}
    nav button{background:transparent;border:none;color:var(--muted);cursor:pointer;padding:8px 10px;border-radius:6px}
    nav button.active{color:var(--primary);font-weight:700;border:1px solid var(--border);background:var(--soft)}
    .container{max-width:1100px;margin:20px auto;padding:0 20px}
    h1{font-family:Georgia,serif;font-size:28px;margin:0 0 8px;color:var(--primary)}
    .lead{color:var(--muted);margin:0 0 18px;max-width:60ch}
    .controls{display:flex;justify-content:space-between;align-items:center;margin:18px 0;gap:12px;flex-wrap:wrap}
    .btn{background:var(--primary);color:#fff;padding:10px 14px;border-radius:6px;border:none;cursor:pointer;font-weight:600}
    .btn.ghost{background:transparent;color:var(--primary);border:1px solid var(--border)}
    .filters-panel{background:var(--soft);border:1px solid var(--border);padding:12px;border-radius:8px;display:flex;gap:12px;flex-wrap:wrap}
    .filter-group{min-width:160px;flex:1}
    label.small{display:block;font-size:12px;color:var(--muted);margin-bottom:6px;font-weight:600}
    input[type="text"], input[type="number"], select{width:100%;Padding:8px;border-radius:6px;border:1px solid var(--border);background:#fff}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;margin-top:18px}
    .card{background:var(--card);border-radius:8px;border:1px solid var(--border);overflow:hidden;display:flex;flex-direction:column;cursor:pointer}
    .thumb{width:100%;height:260px;object-fit:contain;background:#fafafa;display:block}
    .card-body{padding:12px;display:flex;flex-direction:column;gap:8px;flex:1}
    .meta{font-size:13px;color:var(--muted)}
    .name{font-weight:700;color:var(--accent);font-size:15px}
    .cat{font-size:12px;color:#9ca3af}
    .modal{position:fixed;inset:0;display:none;align-items:center;justify-content:center;background:rgba(15,23,42,0.6);z-index:60;padding:20px}
    .modal.open{display:flex}
    .modal-card{background:#fff;border-radius:10px;max-width:920px;width:100%;max-height:90vh;overflow:auto;padding:18px;border:1px solid var(--border)}
    .modal-grid{display:flex;gap:18px;flex-wrap:wrap}
    .modal-img{max-width:420px;width:100%;height:auto;object-fit:contain;background:#fafafa;border-radius:8px;padding:8px;border:1px solid var(--border)}
    .modal-details input, .modal-details select{margin-bottom:8px}
    .empty{padding:28px;text-align:center;color:var(--muted)}
    .hidden{display:none !important}
    .checkbox-list{max-height:220px;overflow:auto;padding:6px;border:1px solid var(--border);border-radius:6px;background:#fff}
    .checkbox-list label{display:flex;align-items:center;gap:8px;padding:6px 4px;cursor:pointer}
    .outfit-thumb{width:120px;height:120px;object-fit:contain;border-radius:6px;background:#fafafa;border:1px solid var(--border);padding:6px}
    @media (max-width:980px){ .thumb{height:200px} .modal-grid{flex-direction:column} .outfit-thumb{width:90px;height:90px} }
  </style>
</head>
<body>
  <header>
    <div class="brand">WEAR TO WARDROBE</div>
    <nav aria-label="Main navigation">
      <button id="nav-closet" class="active" onclick="switchView('closet')">Closet</button>
      <button id="nav-add" onclick="switchView('add')">Add</button>
      <button id="nav-builder" onclick="switchView('builder')">Build</button>
      <button id="nav-outfits" onclick="switchView('outfits')">Outfits</button>
    </nav>
  </header>

  <main class="container">
    <section id="view-closet" class="view">
      <h1>My Closet</h1>
      <p class="lead">A clean, minimal wardrobe manager. Filters are inactive by default so you always see all items unless you choose otherwise.</p>

      <div class="controls">
        <div class="left">
          <button id="toggle-filters" class="btn ghost">Show filters</button>
        </div>
        <div style="display:flex;gap:8px">
          <button id="download-btn" class="btn">Download HTML</button>
        </div>
      </div>

      <div id="filters-area" class="filters-panel hidden" style="display:none">
        <div class="filter-group">
          <label class="small" for="filter-name">Name contains</label>
          <input id="filter-name" type="text" placeholder="e.g., denim">
        </div>
        <div class="filter-group">
          <label class="small">Category (multi)</label>
          <div id="filter-category-list" class="checkbox-list"></div>
        </div>
        <div class="filter-group">
          <label class="small" for="filter-tags">Tags (multi)</label>
          <select id="filter-tags" multiple></select>
        </div>
        <div class="filter-group">
          <label class="small">Colour (multi)</label>
          <select id="filter-colour" multiple></select>
        </div>
      </div>

      <div id="closet-grid" class="grid" aria-live="polite"></div>
      <div id="empty" class="empty hidden">No items match your filters. <button onclick="clearFilters()" class="btn ghost" style="margin-left:8px">Clear filters</button></div>
    </section>

    <section id="view-add" class="view hidden" style="display:none">
      <h1>Add Item</h1>
      <p class="lead">Upload an image and add details. Category defaults to All Items.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end">
        <div style="min-width:220px">
          <label class="small">Upload image</label>
          <input id="item-image" type="file" accept="image/*">
        </div>
        <div style="min-width:220px">
          <label class="small">Item name</label>
          <input id="item-name" type="text" placeholder="Black denim jacket">
        </div>
        <div style="min-width:160px">
          <label class="small">Brand</label>
          <input id="item-brand" type="text" placeholder="Levi's">
        </div>
        <div style="min-width:120px">
          <label class="small">Size</label>
          <input id="item-size" type="text" placeholder="M">
        </div>
        <div style="min-width:160px">
          <label class="small">Price</label>
          <div style="display:flex;gap:8px;align-items:center"><span style="padding:8px 10px;background:#fff;border:1px solid var(--border);border-radius:6px">$</span><input id="item-price" type="number" step="0.01" min="0" placeholder="49.99" style="flex:1"></div>
        </div>
      </div>

      <div style="display:flex;gap:12px;margin-top:12px;flex-wrap:wrap">
        <div style="min-width:220px">
          <label class="small">Category (multi)</label>
          <div id="item-category-list" class="checkbox-list"></div>
          <div style="display:flex;gap:8px;margin-top:8px">
            <input id="new-category-input" type="text" placeholder="Add category (e.g., Jumpsuit)">
            <button onclick="addNewCategoryFromInput()" class="btn ghost">Add</button>
          </div>
        </div>
        <div style="min-width:220px">
          <label class="small">Colour (multi)</label>
          <select id="item-colour" multiple></select>
        </div>
        <div style="min-width:220px">
          <label class="small">Tags (multi or add new)</label>
          <select id="item-tags" multiple style="height:110px"></select>
          <div style="display:flex;gap:8px;margin-top:8px">
            <input id="new-tag-input" type="text" placeholder="Add tag (Mini)">
            <button onclick="addNewTagFromInput()" class="btn">Add</button>
          </div>
        </div>
      </div>

      <div style="margin-top:12px">
        <button onclick="saveItem()" class="btn">Save to Wardrobe</button>
        <button onclick="resetAddForm()" class="btn ghost" style="margin-left:8px">Reset</button>
      </div>
    </section>

    <section id="view-builder" class="view hidden" style="display:none">
      <h1>Create An Outfit</h1>
      <p class="lead">Find items using category and colour, tap to select them, then save as an outfit.</p>
      <div class="filters-panel" style="margin-bottom:12px">
        <div class="filter-group">
          <label class="small">Category (multi)</label>
          <div id="builder-filter-category-list" class="checkbox-list"></div>
        </div>
        <div class="filter-group">
          <label class="small">Colour (multi)</label>
          <select id="builder-filter-colour" multiple></select>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div id="select-count">Selected: 0 items</div>
        <div>
          <button onclick="saveOutfit()" class="btn">Save Outfit</button>
          <button onclick="clearSelection()" class="btn ghost" style="margin-left:8px">Clear</button>
        </div>
      </div>
      <div id="builder-grid" class="grid"></div>
    </section>

    <section id="view-outfits" class="view hidden" style="display:none">
      <h1>Saved Outfits</h1>
      <div id="outfits-list" style="margin-top:12px"></div>
    </section>
  </main>

  <div id="item-modal" class="modal" role="dialog" aria-modal="true">
    <div class="modal-card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div style="font-weight:700" id="modal-title">Item</div>
        <div><button onclick="closeModal()" class="btn ghost">Close</button></div>
      </div>
      <div class="modal-grid">
        <img id="modal-image" class="modal-img" alt="Item image">
        <div class="modal-details">
          <label class="small">Name</label><input id="modal-name" type="text">
          <label class="small">Brand</label><input id="modal-brand" type="text">
          <label class="small">Size</label><input id="modal-size" type="text">
          <label class="small">Price</label>
          <div style="display:flex;gap:8px;align-items:center"><span style="padding:8px 10px;background:#fff;border:1px solid var(--border);border-radius:6px">$</span><input id="modal-price" type="number" step="0.01" min="0" style="flex:1"></div>
          <label class="small">Category</label><div id="modal-category-list" class="checkbox-list"></div>
          <label class="small">Colour</label><select id="modal-colour" multiple style="width:100%;height:120px"></select>
          <label class="small">Tags</label><select id="modal-tags" multiple style="width:100%;height:90px"></select>
          <div style="display:flex;gap:8px;margin-top:12px">
            <button onclick="updateItem()" class="btn">Save changes</button>
            <button onclick="deleteItem()" class="btn" style="background:#ef4444">Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
  let db; const DB_NAME='WardrobeDB_v3'; const DB_VERSION=1;
  let CATEGORIES=['All Items','Belts','Blazer','Blouse','Bomber','Boots','Bottoms','Cardigan','Dresses','Flats','Heels','Jeans','Outerwear','Pants','Sandals','Shoes','Shorts','Skirts','Sneakers','Sweaters','Swimwear','Tops','Trousers'];
  const COLOURS=['Black','Blue','Brown','Camel','Cream','Gold','Green','Grey','Orange','Pink','Purple','Red','Silver','Tan','Teal','White','Yellow'];
  let TAGS=['Mini','Midi','Maxi'];

  const req=indexedDB.open(DB_NAME,DB_VERSION);
  req.onupgradeneeded=e=>{db=e.target.result; if(!db.objectStoreNames.contains('items')) db.createObjectStore('items',{keyPath:'id',autoIncrement:true}); if(!db.objectStoreNames.contains('outfits')) db.createObjectStore('outfits',{keyPath:'id',autoIncrement:true});};
  req.onsuccess=e=>{db=e.target.result; initApp();};
  req.onerror=e=>console.error('DB error',e);

  function escapeHtml(s){ if(!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
  function readSelectMulti(sel){ return sel ? Array.from(sel.selectedOptions).map(o=>o.value) : []; }

  function renderCategoryCheckboxes(containerId, includeAll=true){
    const container=document.getElementById(containerId); if(!container) return; container.innerHTML=''; const cats=CATEGORIES.slice(); if(includeAll && cats[0]!=='All Items') cats.unshift('All Items');
    cats.forEach(cat=>{ const id=containerId+'-opt-'+cat.replace(/\s+/g,'-').toLowerCase(); const label=document.createElement('label'); label.innerHTML='<input type="checkbox" id="'+id+'" value="'+escapeHtml(cat)+'"><span>'+escapeHtml(cat)+'</span>'; container.appendChild(label); const cb=label.querySelector('input'); cb.addEventListener('change',()=>{ const allCb=container.querySelector('input[value="All Items"]'); if(cb.value==='All Items' && cb.checked){ Array.from(container.querySelectorAll('input')).forEach(i=>{ if(i!==cb) i.checked=false; }); } else if(cb.checked){ if(allCb) allCb.checked=false; } }); });
  }

  function readCategoryCheckboxes(containerId){ const container=document.getElementById(containerId); if(!container) return []; const checked=Array.from(container.querySelectorAll('input:checked')).map(i=>i.value); if(checked.includes('All Items')) return []; return checked; }
  function setCategoryCheckboxes(selected=[],containerId){ const container=document.getElementById(containerId); if(!container) return; if(!selected||selected.length===0){ Array.from(container.querySelectorAll('input')).forEach(i=>i.checked=(i.value==='All Items')); return; } Array.from(container.querySelectorAll('input')).forEach(i=>{ i.checked=selected.includes(i.value); }); const allCb=container.querySelector('input[value="All Items"]'); if(allCb && selected.length>0) allCb.checked=false; }

  function populateSelects(){ ['item-category-list','modal-category-list','filter-category-list','builder-filter-category-list'].forEach(id=>renderCategoryCheckboxes(id)); const colourEls=['filter-colour','item-colour','modal-colour','builder-filter-colour'].map(id=>document.getElementById(id)).filter(Boolean); colourEls.forEach(sel=>{ sel.innerHTML=''; COLOURS.forEach(c=>sel.insertAdjacentHTML('beforeend','<option value="'+escapeHtml(c)+'">'+escapeHtml(c)+'</option>')); }); const tagEls=['filter-tags','item-tags','modal-tags'].map(id=>document.getElementById(id)).filter(Boolean); tagEls.forEach(sel=>{ sel.innerHTML=''; TAGS.forEach(t=>sel.insertAdjacentHTML('beforeend','<option value="'+escapeHtml(t)+'">'+escapeHtml(t)+'</option>')); }); const filterCat=document.getElementById('filter-category-list'); if(filterCat) setCategoryCheckboxes([], 'filter-category-list'); const builderCat=document.getElementById('builder-filter-category-list'); if(builderCat) setCategoryCheckboxes([], 'builder-filter-category-list'); }

  function addCategory(cat){ if(!cat) return; cat=cat.trim(); if(!cat) return; if(!CATEGORIES.includes(cat)) CATEGORIES.push(cat); populateSelects(); }
  function addNewCategoryFromInput(){ const v=document.getElementById('new-category-input').value.trim(); if(!v) return; addCategory(v); const itemCat=document.getElementById('item-category-list'); if(itemCat) setCategoryCheckboxes([v],'item-category-list'); document.getElementById('new-category-input').value=''; }
  function addTag(tag){ if(!tag) return; tag=tag.trim(); if(!tag) return; if(!TAGS.includes(tag)) TAGS.push(tag); populateSelects(); }
  function addNewTagFromInput(){ const v=document.getElementById('new-tag-input').value.trim(); if(!v) return; addTag(v); document.getElementById('new-tag-input').value=''; }

  function resizeImageFile(file,maxSize=1200){ return new Promise((resolve,reject)=>{ const reader=new FileReader(); reader.onload=e=>{ const img=new Image(); img.onload=()=>{ let w=img.width,h=img.height; if(w>h && w>maxSize){ h=Math.round(h*(maxSize/w)); w=maxSize; } else if(h>w && h>maxSize){ w=Math.round(w*(maxSize/h)); h=maxSize; } const canvas=document.createElement('canvas'); canvas.width=w; canvas.height=h; const ctx=canvas.getContext('2d'); ctx.drawImage(img,0,0,w,h); resolve(canvas.toDataURL('image/jpeg',0.85)); }; img.onerror=reject; img.src=e.target.result; }; reader.onerror=reject; reader.readAsDataURL(file); }); }

  function resetAddForm(){ document.getElementById('item-image').value=''; document.getElementById('item-name').value=''; document.getElementById('item-brand').value=''; document.getElementById('item-size').value=''; document.getElementById('item-price').value=''; setCategoryCheckboxes([], 'item-category-list'); const col=document.getElementById('item-colour'); if(col) col.selectedIndex=-1; const tags=document.getElementById('item-tags'); if(tags) tags.selectedIndex=-1; }

  async function saveItem(){ const fileInput=document.getElementById('item-image'); const name=document.getElementById('item-name').value.trim(); const brand=document.getElementById('item-brand').value.trim(); const size=document.getElementById('item-size').value.trim(); const price=document.getElementById('item-price').value?parseFloat(document.getElementById('item-price').value):null; let category=readCategoryCheckboxes('item-category-list'); const colour=readSelectMulti(document.getElementById('item-colour')); const tags=readSelectMulti(document.getElementById('item-tags')); if(!name){ alert('Please provide an item name'); return; } if(!fileInput.files||fileInput.files.length===0){ alert('Please upload an image'); return; } try{ const dataUrl=await resizeImageFile(fileInput.files[0]); const item={image:dataUrl,name,brand,size,price,season:[],category,occasion:[],colour,tags,createdAt:Date.now()}; const tx=db.transaction('items','readwrite'); tx.objectStore('items').add(item); tx.oncomplete=()=>{ resetAddForm(); switchView('closet'); renderCloset(); alert('Saved'); }; tx.onerror=e=>{ console.error(e); alert('Save failed'); }; }catch(err){ console.error(err); alert('Image processing failed'); } }

  function getFilterSelections(){ const name=(document.getElementById('filter-name').value||'').trim(); const category=readCategoryCheckboxes('filter-category-list'); const tags=readSelectMulti(document.getElementById('filter-tags')); const colour=readSelectMulti(document.getElementById('filter-colour')); return {name,category,tags,colour}; }
  function matchesMultiFilter(itemArray,filterArray,itemEmptyMeansWildcard=false){ if(!filterArray||filterArray.length===0) return true; if(filterArray.includes('All Items')) return true; if(!itemArray||itemArray.length===0) return itemEmptyMeansWildcard; return filterArray.some(f=>itemArray.includes(f)); }
  function filtersAreActive(){ const f=getFilterSelections(); if(f.name) return true; if(f.category.length && !(f.category.length===1 && f.category[0]==='All Items')) return true; if(f.tags.length) return true; if(f.colour.length) return true; return false; }

  function renderCloset(){ const grid=document.getElementById('closet-grid'); grid.innerHTML=''; const emptyEl=document.getElementById('empty'); emptyEl.classList.add('hidden'); if(!db) return; const active=filtersAreActive(); const f=getFilterSelections(); const nameFilter=(f.name||'').toLowerCase(); const categoryFilter=f.category; const tagsFilter=f.tags; const colourFilter=f.colour; let count=0; const store=db.transaction('items').objectStore('items'); store.openCursor().onsuccess=function(e){ const cursor=e.target.result; if(!cursor){ if(count===0) emptyEl.classList.remove('hidden'); return; } const item=cursor.value; if(!active){ appendCard(item); count++; cursor.continue(); return; } if(nameFilter && (!item.name || !item.name.toLowerCase().includes(nameFilter))){ cursor.continue(); return; } if(!matchesMultiFilter(item.category||[],categoryFilter,true)){ cursor.continue(); return; } if(!matchesMultiFilter(item.tags||[],tagsFilter,false)){ cursor.continue(); return; } if(!matchesMultiFilter(item.colour||[],colourFilter,false)){ cursor.continue(); return; } appendCard(item); count++; cursor.continue(); }; }

  function appendCard(item){ const grid=document.getElementById('closet-grid'); const card=document.createElement('div'); card.className='card'; const img=document.createElement('img'); img.className='thumb'; img.src=item.image; img.alt=item.name||'item'; const body=document.createElement('div'); body.className='card-body'; const name=document.createElement('div'); name.className='name'; name.innerText=item.name||''; const meta=document.createElement('div'); meta.className='meta'; const brand=item.brand?item.brand:''; const size=item.size? ' • '+item.size : ''; const price=(item.price!==undefined && item.price!==null)? ' • $'+Number(item.price).toFixed(2) : ''; meta.innerText=brand+size+price; const cat=document.createElement('div'); cat.className='cat'; cat.innerText=(item.category && item.category.length)? item.category.slice(0,2).join(', ') : 'All Items'; const tags=document.createElement('div'); tags.className='meta'; tags.style.marginTop='6px'; tags.style.fontSize='12px'; tags.style.color='var(--muted)'; tags.innerText=(item.tags && item.tags.length)? 'Tags: '+item.tags.join(', ') : ''; body.appendChild(name); body.appendChild(meta); body.appendChild(cat); if(tags.innerText) body.appendChild(tags); card.appendChild(img); card.appendChild(body); card.onclick=()=>openModal(item.id); grid.appendChild(card); }

  let currentModalId=null;
  function openModal(id){ currentModalId=id; const tx=db.transaction('items').objectStore('items'); tx.get(id).onsuccess=e=>{ const item=e.target.result; if(!item) return; document.getElementById('modal-image').src=item.image; document.getElementById('modal-title').innerText=item.name; document.getElementById('modal-name').value=item.name||''; document.getElementById('modal-brand').value=item.brand||''; document.getElementById('modal-size').value=item.size||''; document.getElementById('modal-price').value=(item.price!==undefined && item.price!==null)?item.price:''; setCategoryCheckboxes(item.category||[],'modal-category-list'); setSelectMulti(document.getElementById('modal-colour'),item.colour||[]); setSelectMulti(document.getElementById('modal-tags'),item.tags||[]); document.getElementById('item-modal').classList.add('open'); }; }
  function closeModal(){ document.getElementById('item-modal').classList.remove('open'); currentModalId=null; }
  function setSelectMulti(sel,arr){ if(!sel) return; Array.from(sel.options).forEach(o=>o.selected=arr && arr.includes(o.value)); }

  function updateItem(){ if(!currentModalId) return; const name=document.getElementById('modal-name').value.trim(); const brand=document.getElementById('modal-brand').value.trim(); const size=document.getElementById('modal-size').value.trim(); const price=document.getElementById('modal-price').value?parseFloat(document.getElementById('modal-price').value):null; let category=readCategoryCheckboxes('modal-category-list'); if(category.includes('All Items')) category=[]; const colour=readSelectMulti(document.getElementById('modal-colour')); const tags=readSelectMulti(document.getElementById('modal-tags')); const tx=db.transaction('items','readwrite'); const store=tx.objectStore('items'); store.get(currentModalId).onsuccess=e=>{ const item=e.target.result; if(!item) return; item.name=name; item.brand=brand; item.size=size; item.price=price; item.category=category; item.colour=colour; item.tags=tags; store.put(item); tx.oncomplete=()=>{ closeModal(); renderCloset(); alert('Updated'); }; tx.onerror=()=>alert('Update failed'); }; }

  function deleteItem(){ if(!currentModalId) return; if(!confirm('Delete this item?')) return; const tx=db.transaction('items','readwrite'); tx.objectStore('items').delete(currentModalId); tx.oncomplete=()=>{ closeModal(); renderCloset(); alert('Deleted'); }; }

  let selectedItems=[];
  function renderBuilderGrid(){ const grid=document.getElementById('builder-grid'); grid.innerHTML=''; if(!db) return; const categoryFilter=readCategoryCheckboxes('builder-filter-category-list'); const colourFilter=readSelectMulti(document.getElementById('builder-filter-colour')); const builderActive=(categoryFilter.length && !(categoryFilter.length===1 && categoryFilter[0]==='All Items')) || colourFilter.length; const store=db.transaction('items').objectStore('items'); store.openCursor().onsuccess=function(e){ const c=e.target.result; if(!c) return; const item=c.value; if(!builderActive){ appendBuilderCard(item); c.continue(); return; } if(!matchesMultiFilter(item.category||[],categoryFilter,true)){ c.continue(); return; } if(!matchesMultiFilter(item.colour||[],colourFilter,false)){ c.continue(); return; } appendBuilderCard(item); c.continue(); }; }

  function appendBuilderCard(item){ const grid=document.getElementById('builder-grid'); const card=document.createElement('div'); card.className='card'; if(selectedItems.includes(item.id)) card.style.outline='3px solid rgba(79,70,229,0.12)'; const img=document.createElement('img'); img.className='thumb'; img.src=item.image; img.alt=item.name||'item'; const body=document.createElement('div'); body.className='card-body'; const name=document.createElement('div'); name.className='name'; name.innerText=item.name||''; const meta=document.createElement('div'); meta.className='meta'; meta.innerText=item.brand||''; body.appendChild(name); body.appendChild(meta); card.appendChild(img); card.appendChild(body); card.onclick=function(){ const idx=selectedItems.indexOf(item.id); if(idx>-1) selectedItems.splice(idx,1); else selectedItems.push(item.id); document.getElementById('select-count').innerText='Selected: '+selectedItems.length+' items'; renderBuilderGrid(); }; grid.appendChild(card); }

  function clearSelection(){ selectedItems=[]; document.getElementById('select-count').innerText='Selected: 0 items'; renderBuilderGrid(); }

  function saveOutfit(){ if(selectedItems.length<2){ alert('Select at least 2 items'); return; } const name=prompt('Name this outfit:'); if(!name) return; const imgs=[]; let loaded=0; const store=db.transaction('items').objectStore('items'); selectedItems.forEach(id=>{ store.get(id).onsuccess=function(e){ imgs.push(e.target.result.image); loaded++; if(loaded===selectedItems.length){ const tx=db.transaction('outfits','readwrite'); tx.objectStore('outfits').add({name,itemImages:imgs}); tx.oncomplete=function(){ alert('Outfit saved'); selectedItems=[]; switchView('outfits'); }; } }; }); }

  function renderOutfits(){ const list=document.getElementById('outfits-list'); list.innerHTML=''; const store=db.transaction('outfits').objectStore('outfits'); store.openCursor().onsuccess=function(e){ const c=e.target.result; if(!c) return; const o=c.value; const div=document.createElement('div'); div.style.marginBottom='18px'; div.innerHTML='<div style="font-weight:700;margin-bottom:8px">'+escapeHtml(o.name)+'</div>'; const row=document.createElement('div'); row.style.display='flex'; row.style.gap='12px'; row.style.flexWrap='wrap'; (o.itemImages||[]).forEach(i=>{ const img=document.createElement('img'); img.src=i; img.className='outfit-thumb'; row.appendChild(img); }); div.appendChild(row); list.appendChild(div); c.continue(); }; }

  function clearFilters(){ document.getElementById('filter-name').value=''; setCategoryCheckboxes([], 'filter-category-list'); const tags=document.getElementById('filter-tags'); if(tags) tags.selectedIndex=-1; const col=document.getElementById('filter-colour'); if(col) col.selectedIndex=-1; renderCloset(); }

  function downloadHTML(){ const items=[]; const tx=db.transaction('items').objectStore('items'); tx.openCursor().onsuccess=function(e){ const c=e.target.result; if(!c){ const exportHtml=buildExportHtml(items); const blob=new Blob([exportHtml],{type:'text/html'}); const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download='wardrobe_export.html'; document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url); return; } items.push(c.value); c.continue(); }; }
  function buildExportHtml(items){ const rows=[]; rows.push('<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Wardrobe Export</title><style>body{font-family:Arial,Helvetica,sans-serif;padding:20px}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}.card{border:1px solid #eee;padding:8px;border-radius:6px}img{width:100%;height:200px;object-fit:contain;background:#fafafa}</style></head><body>'); rows.push('<h1>Wardrobe Export</h1>'); rows.push('<div class="grid">'); items.forEach(it=>{ rows.push('<div class="card">'); rows.push('<img src="'+it.image+'">'); rows.push('<div><strong>'+escapeHtml(it.name||'')+'</strong></div>'); rows.push('<div>'+escapeHtml((it.category && it.category.length)?it.category.join(', '):'All Items')+'</div>'); rows.push('<div>'+escapeHtml((it.tags||[]).join(', '))+'</div>'); rows.push('</div>'); }); rows.push('</div></body></html>'); return rows.join('\n'); }

  function switchView(viewName){ document.querySelectorAll('.view').forEach(v=>{ v.classList.add('hidden'); v.style.display='none'; }); document.getElementById('view-'+viewName).classList.remove('hidden'); document.getElementById('view-'+viewName).style.display='block'; document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active')); const navBtn=document.getElementById('nav-'+viewName); if(navBtn) navBtn.classList.add('active'); if(viewName==='closet') renderCloset(); if(viewName==='builder') renderBuilderGrid(); if(viewName==='outfits') renderOutfits(); }

  function initApp(){ populateSelects(); renderCloset(); const toggleBtn=document.getElementById('toggle-filters'); const filtersArea=document.getElementById('filters-area'); toggleBtn.addEventListener('click',()=>{ const isHidden=filtersArea.classList.toggle('hidden'); filtersArea.style.display=isHidden?'none':'flex'; toggleBtn.innerText=isHidden?'Show filters':'Hide filters'; }); document.getElementById('download-btn').addEventListener('click',downloadHTML); ['filter-tags','filter-colour'].forEach(id=>{ const el=document.getElementById(id); if(el) el.addEventListener('change',()=>renderCloset()); }); const nameEl=document.getElementById('filter-name'); if(nameEl) nameEl.addEventListener('input',debounce(()=>renderCloset(),220)); ['builder-filter-category-list','builder-filter-colour'].forEach(id=>{ const el=document.getElementById(id); if(!el) return; el.addEventListener('change',()=>renderBuilderGrid()); }); document.getElementById('item-modal').addEventListener('click',(e)=>{ if(e.target.id==='item-modal') closeModal(); }); window.saveItem=saveItem; window.resetAddForm=resetAddForm; window.clearFilters=clearFilters; window.addNewTagFromInput=addNewTagFromInput; window.openModal=openModal; window.closeModal=closeModal; window.updateItem=updateItem; window.deleteItem=deleteItem; window.saveOutfit=saveOutfit; window.clearSelection=clearSelection; window.downloadHTML=downloadHTML; window.switchView=switchView; window.addNewCategoryFromInput=addNewCategoryFromInput; window.addNewCategory=addCategory; ['filter-category-list','item-category-list','modal-category-list','builder-filter-category-list'].forEach(id=>{ const el=document.getElementById(id); if(el) el.addEventListener('change',()=>{ renderCloset(); renderBuilderGrid(); }); });

    if('serviceWorker' in navigator){
      navigator.serviceWorker.register('service-worker.js').catch(()=>{/* ignore registration errors */});
    }
  }

  function debounce(fn,wait){ let t; return function(...args){ clearTimeout(t); t=setTimeout(()=>fn.apply(this,args),wait); }; }

  window.renderCloset=renderCloset; window.renderBuilderGrid=renderBuilderGrid; window.renderOutfits=renderOutfits;
  </script>
</body>
</html>

